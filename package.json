{
  "name": "gestao-escolar",
  "version": "1.0.0",
  "private": true,
  "description": "Monorepo do sistema de gestão escolar EduGestao (apps/web + apps/api)",
  "scripts": {
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "db:up": "docker compose up -d db",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f db",
    "api:install": "npm --prefix apps/api install",
    "api:setup": "npm --prefix apps/api run prisma:migrate && npm --prefix apps/api run prisma:seed",
    "api:dev": "npm --prefix apps/api run start:dev",
    "api:test": "npm --prefix apps/api test",
    "web:install": "npm --prefix apps/web install",
    "web:dev": "npm --prefix apps/web run dev"
  }
}
